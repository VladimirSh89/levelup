# Level Up Barbershop — production deploy (copy to .env.deploy; never commit)
# Used by scripts/deploy-prod.sh. Lines are valid bash assignments only.

# --- SSH / target (reuse Namecheap host from ~/.ssh/config) ---
PROD_SSH_TARGET=namecheap
PROD_SSH_KEY_PATH=~/.ssh/codensgo_namecheap

# Public URL (cPanel subdomain — keep Share document root UNCHECKED)
PROD_URL=https://levelup.codebridgestudio.com
PROD_BASE_URL=https://levelup.codebridgestudio.com
PROD_API_URL=https://levelup.codebridgestudio.com/api

# Matches cPanel "Document Root" for levelup.codebridgestudio.com
# Frontend (Vite dist) → document root; API + prisma sit as siblings under APP_ROOT
PROD_APP_ROOT=/home/codensgo/levelup.codebridgestudio.com
PROD_PUBLIC_DIR=/home/codensgo/levelup.codebridgestudio.com
PROD_API_DIR=/home/codensgo/levelup-api

PROD_SERVER_TYPE=apache
PROD_PROCESS_MANAGER=passenger
PM2_APP_NAME=levelup-api

PROD_BACKUP_DIR=/home/codensgo/backups/levelup
BACKUP_RETENTION_COUNT=5
PROD_API_ENV_FILE=/home/codensgo/levelup-api/.env

SMOKE_TEST_TIMEOUT=30
REQUIRED_DEPLOY_BRANCH=main

# MySQL on cPanel (create DB + user in cPanel MySQL Databases first)
# Real credentials live only in gitignored .env.deploy / remote api/.env
# DATABASE_URL="mysql://codensgo_levelup:URL_ENCODED_PASSWORD@localhost:3306/codensgo_levelup"
