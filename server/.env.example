# Local MySQL — Homebrew default port 3306, or Docker (`npm run dev:mysql`) on 3307:
# DATABASE_URL="mysql://levelup:levelup@localhost:3307/levelup"
DATABASE_URL="mysql://levelup:levelup@localhost:3306/levelup"

# Auth
JWT_SECRET="change-me-in-production"

# Server
PORT=3001
CLIENT_URL="http://localhost:5173"

# Email (optional — omit SMTP_HOST to use the dev stub, which logs instead of sending)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=xxx
# SMTP_PASS=xxx
# MAIL_FROM="Level Up Barbershop <no-reply@levelupbarbershop.com>"

# Seed overrides (optional)
# SEED_ADMIN_EMAIL=admin@levelup.local
# SEED_ADMIN_PASSWORD=Admin123!
